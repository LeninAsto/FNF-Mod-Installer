    <string name="how_to_use_title">How to use?</string>
    <string name="how_to_use_content">1. Enable the engines you need in Settings (⚙️).\n2. Link the \'mods\' folder for each engine.\n3. After reinstalling, you must link again due to Android security.</string>

    <string name="installation_guide_title">Installation Guide</string>
    <string name="data_folder_install_title">Data folder installation</string>
    <string name="data_folder_install_content">For engines using Scoped Storage (FNF Mobile, Plus Engine, P-Slice Scoped):\n\n1. Open the game at least once.\n2. Go to a file manager and navigate to Android/data/PACKAGE_NAME/files.\n3. Make sure the \'mods\' folder exists.\n4. Return to this app, go to the engine tab and click \'Link Now\'.\n5. Select the \'mods\' folder in the system picker.</string>

    <string name="other_engines_title">Other Engines</string>
    <string name="other_engines_content">Engines like Psych or NovaFlare use folders in the root of your storage (.PsychEngine, .novaflareengine). Simply enable them in Settings and link the mods folder inside them.</string>

    <string name="why_unlink_title">Why do folders get unlinked?</string>
    <string name="why_unlink_content">Android revokes folder permissions when uninstalling an app for security. If you reinstall, just press \'Link Now\' again.</string>

