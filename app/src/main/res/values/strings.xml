    <string name="how_to_use_title">How to use?</string>
    <string name="how_to_use_content">1. Enable the engines you need in Settings (⚙️).\n2. Link the \'mods\' folder for each engine.\n3. After reinstalling, you must link again due to Android security.</string>

    <string name="installation_guide_title">Installation Guide</string>

    <string name="guide_scoped_title">Scoped Storage Installation</string>
    <string name="guide_scoped_content">For engines in Android/data:\n1. Go to the game settings and use the \"Open Data Folder\" option (if available).\n2. Once the system folder opens, you can close the game.\n3. Return to this app and use \"Link Now\" to select that same folder.</string>

    <string name="guide_external_title">External Storage Installation</string>
    <string name="guide_external_content">For engines like Psych or NovaFlare, simply navigate to the corresponding folder in your internal storage (e.g., .PsychEngine/mods) and grant access.</string>

    <string name="guide_unlinking_title">Why folders get unlinked?</string>
    <string name="guide_unlinking_content">Android may revoke folder permissions after an app update, system restart, or if the app cache is cleared. If this happens, just press \"Link Now\" again to restore access.</string>

